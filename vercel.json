{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/report",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "https://get-an-expert-chat-production.up.railway.app/mcp"
    },
    {
      "source": "/classic",
      "destination": "/classic/index.html"
    }
  ],
  "headers": [
    {
      "source": "/mcp",
      "headers": [
        { "key": "x-vercel-enable-rewrite-caching", "value": "0" }
      ]
    }
  ]
}
