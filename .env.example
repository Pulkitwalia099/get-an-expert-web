# Powers the intake questions (claude-opus-4-8). Without it the chat runs a scripted demo flow.
ANTHROPIC_API_KEY=

# Live profile search across Upwork, Fiverr and the open web (serpapi.com).
# Without it three demo profiles are returned.
SERPAPI_KEY=

# Optional. Each brief, intro request and custom need is POSTed here as JSON
# (point it at an n8n/Zapier webhook to collect the dataset).
INSIGHTS_WEBHOOK_URL=

# Supabase. Sessions, messages, searches and leads are written from server
# routes only, so this must be the SECRET key (sb_secret_...), not the
# publishable one. Row Level Security is on and the publishable key gets no
# read access to any table, so it is not used by this app.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Daily monitoring email. CRON_SECRET protects /api/report; Vercel sends it
# automatically as a Bearer token when the env var is set. RESEND_API_KEY
# sends the email through resend.com; without it the report is only logged.
# REPORT_EMAIL is the owner address the report goes to.
CRON_SECRET=
RESEND_API_KEY=
REPORT_EMAIL=

# Optional spend guards, all with sane defaults: DAILY_CAP_CHAT (500),
# DAILY_CAP_SEARCH (150), DAILY_CAP_INTROS (200) requests per day, and
# SERPAPI_MONTHLY_CAP (250) SerpAPI queries per month before searches
# degrade to demo profiles.
